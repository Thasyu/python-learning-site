# Flask backend SMTP settings (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=example@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=example@gmail.com

# Frontend URLs included in emails
PASSWORD_RESET_PAGE_URL=http://127.0.0.1:5500/pages/reset-password.html
EMAIL_CHANGE_CONFIRM_PAGE_URL=http://127.0.0.1:5500/pages/confirm-email-change.html

# Allowed frontend origins for CORS (comma separated)
FRONTEND_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,https://thasyu.github.io
